@{
    ViewData["Title"] = "Live Bitcoin Prices";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Live Bitcoin Prices</h2>
    </div>

    <table id="liveTable" class="table table-striped table-hover align-middle">

        <thead>
            <tr>
                <th></th>
                <th>Downloaded</th>
                <th>BTC price in EUR</th>
                <th>EUR to CZK rate</th>
                <th>BTC price in CZK</th>
            </tr>
        </thead>

        <tbody id="liveTableBody">
        </tbody>

    </table>

    <div class="mt-3">

        <button id="saveBtn"
                class="btn btn-primary">

            Save Selected Data

        </button>

    </div>

</div>

<script>

    const liveData = [];

    async function loadData() {

        const response = await fetch('/api/liveBtcPrice');

        const data = await response.json();

        liveData.push(data);

        appendRow(data);
    }

    function appendRow(item) {

        const downloaded =
        new Intl.DateTimeFormat('cs-CZ', {
            dateStyle: 'short',
            timeStyle: 'medium'
        }).format(new Date(item.downLoaded));

        const priceEur =
            new Intl.NumberFormat('cs-CZ', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(item.priceEur);

        const eurToCzk =
            new Intl.NumberFormat('cs-CZ', {
                minimumFractionDigits: 4,
                maximumFractionDigits: 4
            }).format(item.eurToCzkRate);

        const priceCzk =
            new Intl.NumberFormat('cs-CZ', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(item.priceCzk);

        const tbody =
            document.getElementById("liveTableBody");

        const index = liveData.length - 1;

        tbody.innerHTML =
            `
            <tr>
                <td>
                <input type="checkbox"
                       class="row-checkbox"
                       data-index="${index}" />
                </td>
                <td>${downloaded}</td>
                <td>${priceEur}</td>
                <td>${eurToCzk}</td>
                <td>${priceCzk}</td>
            </tr>
            `
            + tbody.innerHTML;
    }

    document.getElementById("saveBtn")
        .addEventListener("click", async () => {

        const selectedData = [];

        document.querySelectorAll(".row-checkbox:checked")
            .forEach(cb => {

            const index = parseInt(cb.dataset.index);

            selectedData.push(liveData[index]);
        });

        if (selectedData.length === 0) {

            alert("Select at least one record.");

            return;
        }

        const response = await fetch('/api/save',
            {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(selectedData)
            });

        if (response.ok) {

            alert("Data saved.");
        }
        else {

            alert("Failed to save data.");
        }
    });
        
    setInterval(loadData, 10000);

    loadData();

</script>