@using BitcoinPrice.ViewModels
@{
    ViewData["Title"] = "Live Bitcoin Prices";
}

@model LiveBitcoinPriceViewModel

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Live Bitcoin Prices</h2>

        <button class="btn btn-primary">
            Refresh Data
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Downloaded</th>
                    <th>BTC/EUR</th>
                    <th>EUR/CZK</th>
                    <th>BTC/CZK</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.LiveBitcoinPrices.Any())
                {
                    @foreach (var item in Model.LiveBitcoinPrices)
                    {
                        <tr>
                            <td>
                                @item.DownLoaded.ToString("dd.MM.yyyy HH:mm:ss")
                            </td>

                            <td>
                                @item.PriceEur.ToString("N2")
                            </td>

                            <td>
                                @item.EurToCzkRate.ToString("N4")
                            </td>

                            <td class="fw-bold">
                                @item.PriceCzk.ToString("N2") Kč
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">
                            No live data available.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
