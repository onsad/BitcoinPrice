@using BitcoinPrice.ViewModels

@model BitcoinPriceViewModel

@{
    ViewData["Title"] = "Saved Bitcoin Prices";
}

<div class="container mt-4">

    <h2 class="mb-3">
        Saved Bitcoin Prices
    </h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">

            @TempData["Error"]

        </div>
    }

    @using (Html.BeginForm("SavedBitcoinPrice", "BitcoinPrice", FormMethod.Post))
    {
        <table id="savedTable"class="table table-striped table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th></th>
                    <th><a asp-controller="BitcoinPrice" asp-action="SavedBitcoinPrice"
                        asp-route-sortOrder="@ViewData["DownloadedSortParm"]">@Html.DisplayNameFor(model => model.SavedBitcoinPrice.First().DownLoaded)</a>
                    </th>
                    <th>
                        <a asp-controller="BitcoinPrice" asp-action="SavedBitcoinPrice"
                           asp-route-sortOrder="@ViewData["PriceEurSortParm"]">@Html.DisplayNameFor(model => model.SavedBitcoinPrice.First().PriceEur)
                        </a>
                    </th>
                    <th>@Html.DisplayNameFor(model => model.SavedBitcoinPrice.First().EurToCzkRate)</th>
                    <th>
                        <a asp-controller="BitcoinPrice" asp-action="SavedBitcoinPrice" asp-route-sortOrder="@ViewData["PriceCzkSortParm"]">
                            @Html.DisplayNameFor(model => model.SavedBitcoinPrice.First().PriceCzk)
                        </a>
                    </th>
                    <th>@Html.DisplayNameFor(model => model.SavedBitcoinPrice.First().Note)</th>
                </tr>
            </thead>

            <tbody>

                @for (int i = 0; i < Model.SavedBitcoinPrice.Count; i++)
                {
                    <tr>
                        <td class="text-center">
                            @Html.CheckBoxFor(x => x.SavedBitcoinPrice[i].Selected,
                                new
                                {
                                    @class = "form-check-input"
                                })
                        </td>

                        <td>
                            @Html.DisplayFor(model => model.SavedBitcoinPrice[i].DownLoaded)
                        </td>

                        <td>
                            @Html.DisplayFor(model => model.SavedBitcoinPrice[i].PriceEur)
                        </td>

                        <td>
                            @Html.DisplayFor(model => model.SavedBitcoinPrice[i].EurToCzkRate)
                        </td>

                        <td>
                            @Html.DisplayFor(model => model.SavedBitcoinPrice[i].PriceCzk)
                        </td>

                        <td>
                            @Html.TextBoxFor(
                                x => x.SavedBitcoinPrice[i].Note,
                                new
                                {
                                    @class = "form-control"
                                })

                            @Html.ValidationMessageFor(
                                x => x.SavedBitcoinPrice[i].Note,
                                "",
                                new
                                {
                                    @class = "text-danger"
                                })

                        </td>

                    </tr>

                    @Html.HiddenFor(x => x.SavedBitcoinPrice[i].Id)

                    @Html.HiddenFor(x => x.SavedBitcoinPrice[i].PriceEur)

                    @Html.HiddenFor(x => x.SavedBitcoinPrice[i].EurToCzkRate)

                    @Html.HiddenFor(x => x.SavedBitcoinPrice[i].PriceCzk)

                    @Html.HiddenFor(x => x.SavedBitcoinPrice[i].DownLoaded)

                    @Html.HiddenFor(x => x.SavedBitcoinPrice[i].RowVersion)
                }

            </tbody>

        </table>

        <div class="d-flex gap-2 mt-3">

            <button type="submit"
                    id="saveButton"
                    formaction="@Url.Action("SaveChanges", "BitcoinPrice")"
                    class="btn btn-primary"
                    disabled>

                Save Selected

            </button>

            <button type="submit"
                    id="deleteButton"
                    formaction="@Url.Action("DeleteSelected", "BitcoinPrice")"
                    class="btn btn-danger"
                    onclick="return confirm('Delete selected records?')"
                    disabled>

                Delete Selected

            </button>

        </div>
    }

</div>

@section Scripts
{
    <script>
        function toggleButtons() {

            const checkboxes = document.querySelectorAll(
                '#savedTable input[type="checkbox"]'
            );

            const anyChecked = Array.from(checkboxes)
                .some(x => x.checked);

            document.getElementById('saveButton').disabled = !anyChecked;

            document.getElementById('deleteButton').disabled = !anyChecked;
        }

        document.addEventListener('DOMContentLoaded', function () {

            const checkboxes = document.querySelectorAll(
                '#savedTable input[type="checkbox"]'
            );

            checkboxes.forEach(x => {
                x.addEventListener('change', toggleButtons);
            });

            toggleButtons();
        });
    </script>
}