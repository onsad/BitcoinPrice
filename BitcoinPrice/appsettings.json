{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=BitcoinPriceDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "MarketDataApi": {
    "CoinDeskUrl": "https://data-api.coindesk.com",
    "CoinDeskEndpoint": "/index/cc/v1/latest/tick?market=cadli&instruments=BTC-EUR&apply_mapping=true",

    "CnbUrl": "https://api.cnb.cz",
    "CnbEndpoint": "/cnbapi/exrates/daily"
  }
}
